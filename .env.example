# ============================================================
# OMEGA TEACHER ENGINE - Environment Variables
# ============================================================

# --- GEMINI AI KEYS (Server-Side) ---

# GEMINI_API_KEY: Kunci API Gemini utama server (WAJIB).
# Dapatkan gratis di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy_YOUR_PRIMARY_KEY_HERE"

# GEMINI_API_KEYS_POOL: Kumpulan API Key cadangan (opsional).
# Pisahkan dengan koma. Sistem akan merotasinya secara otomatis (round-robin)
# ketika GEMINI_API_KEY tidak tersedia / kuota habis.
# Contoh: "AIzaSy_KEY1,AIzaSy_KEY2,AIzaSy_KEY3"
GEMINI_API_KEYS_POOL=""

# --- GEMINI AI KEY (Frontend/Vite - TERLIHAT DI BROWSER) ---
# PERINGATAN: Key ini akan ter-embed di bundle frontend dan BISA DILIHAT
# oleh pengguna. Gunakan key gratis dengan kuota terbatas saja di sini.
# Berguna sebagai kunci default sebelum user memasukkan key mandiri mereka.
# Prefix VITE_ wajib ada agar Vite menyertakannya ke bundle.
VITE_GEMINI_API_KEY=""

# ============================================================
# PRIORITAS PENGGUNAAN KEY (DARI TERTINGGI KE TERENDAH):
# 1. Key Mandiri User (dimasukkan di UI aplikasi) — TERTINGGI
# 2. Dynamic Server Key (di-set via /api/save-key)
# 3. GEMINI_API_KEY (env var tunggal)
# 4. GEMINI_API_KEYS_POOL (rotasi round-robin)
# 5. VITE_GEMINI_API_KEY (frontend fallback)
# 6. MASTER_GEMINI_KEY (hardcoded fallback) — TERENDAH
# ============================================================

# APP_URL: URL tempat aplikasi di-hosting (opsional).
APP_URL="MY_APP_URL"

# NODE_ENV: Mode aplikasi. Set ke "production" di Netlify.
NODE_ENV="development"
